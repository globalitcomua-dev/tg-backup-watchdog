# ==============================================================================
# TG Backup Watchdog
# Environment configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------

POSTGRES_DB=backup_watchdog
POSTGRES_USER=backup_watchdog
POSTGRES_PASSWORD=backup_watchdog

# Docker Compose uses hostname "db".
DATABASE_URL=postgresql+psycopg://backup_watchdog:backup_watchdog@db:5432/backup_watchdog

# For local development without Docker use:
# DATABASE_URL=postgresql+psycopg://backup_watchdog:backup_watchdog@localhost:5432/backup_watchdog

# ------------------------------------------------------------------------------
# API
# ------------------------------------------------------------------------------

# Used only by /admin and administrative API endpoints.
# Authorization: Bearer <ADMIN_API_TOKEN>
ADMIN_API_TOKEN=change_me_admin

# ------------------------------------------------------------------------------
# Telegram
# ------------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=
# Required when telegram-listener is enabled. Listener is fail-closed without it.
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_INTERVAL=5
WATCHDOG_CHECK_INTERVAL=300
NOTIFY_ON_INITIAL_STATE=false

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------

LOG_LEVEL=INFO
